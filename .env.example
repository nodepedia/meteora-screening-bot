APP_NAME=Meteora Screening Bot
APP_TIMEZONE=Asia/Jakarta
APP_LOG_LEVEL=info
APP_RUN_ONCE=true
APP_POLL_INTERVAL_MINUTES=15
APP_MAX_CANDIDATES=80
APP_SHORTLIST_LIMIT=10

METEORA_POOL_DISCOVERY_BASE=https://pool-discovery-api.datapi.meteora.ag
METEORA_DLMM_BASE=https://dlmm.datapi.meteora.ag
METEORA_CATEGORY=top
METEORA_DISCOVERY_TIMEFRAME=24h
METEORA_MIN_MARKET_CAP_USD=250000
METEORA_MAX_MARKET_CAP_USD=50000000
METEORA_MIN_TOKEN_AGE_HOURS=2
METEORA_MIN_HOLDERS=500
METEORA_MIN_VOLUME_24H_USD=1000000
METEORA_MIN_VOLUME_1H_USD=1000
METEORA_MIN_TVL_USD=10000
METEORA_MIN_FEE_TVL_RATIO_24H=50
METEORA_MIN_BASE_FEE_PCT=2
METEORA_MAX_BASE_FEE_PCT=10
METEORA_REQUIRED_BIN_STEP=100
METEORA_REQUIRE_BOTH_VERIFIED=true

JUPITER_API_BASE=https://api.jup.ag
JUPITER_DATAPI_BASE=https://datapi.jup.ag/v1
JUPITER_API_KEY=
JUPITER_REQUIRE_VERIFIED=true
JUPITER_MIN_ORGANIC_SCORE=60
JUPITER_MAX_TOP10_HOLDERS_PCT=30
JUPITER_REQUIRE_MINT_AUTHORITY_DISABLED=true
JUPITER_REQUIRE_FREEZE_AUTHORITY_DISABLED=true
JUPITER_MIN_GLOBAL_FEES_SOL=30

OKX_BASE=https://web3.okx.com
OKX_MAX_BUNDLE_PCT=30
OKX_MAX_SUSPICIOUS_PCT=10
OKX_REQUIRE_NOT_WASH=true

RUGCHECK_API_BASE=https://api.rugcheck.xyz/v1
RUGCHECK_MAX_SCORE=30
RUGCHECK_MAX_WARN_RISKS=1
RUGCHECK_REQUIRE_ZERO_DANGER_RISKS=true
RUGCHECK_REQUIRE_NOT_HONEYPOT=true
RUGCHECK_REQUIRE_IMMUTABLE_METADATA=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_STARTUP=true
TELEGRAM_NOTIFY_RESULTS=true
TELEGRAM_NOTIFY_EMPTY=true
TELEGRAM_NOTIFY_ERRORS=true
TELEGRAM_TIMEOUT_MS=15000
TELEGRAM_RETRY_COUNT=1
